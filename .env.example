# Stripe restricted key for this POS only (recommended)
# Create in Dashboard → Developers → API keys → Create restricted key
# Use rk_test_... locally, rk_live_... in Vercel production
STRIPE_SECRET_KEY=rk_test_string

# From Stripe Dashboard → Terminal → Readers → your WisePOS E
STRIPE_READER_ID=tmr_string

# Staff PIN to access the POS (4–8 digits)
POS_ACCESS_PIN=12345

# Random secret for signing sessions — run: openssl rand -hex 32
POS_SESSION_SECRET=change-me-to-a-long-random-string
